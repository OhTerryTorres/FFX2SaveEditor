<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FFX2SaveEditor.Avalonia.MainWindow"
        Title="FFX-2 Save Editor"
        Width="720" Height="400">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="FFX-2 Save Editor" FontSize="24" FontWeight="Bold" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Name="OpenPcButton" Content="Open PC Save" Click="OpenPcButton_Click" Width="140" />
            <Button Name="SavePcButton" Content="Save PC Save" Click="SavePcButton_Click" Width="140" IsEnabled="False" />
        </StackPanel>
        <TextBlock Name="StatusText" Text="Ready" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Loaded file:" FontWeight="Bold" />
            <TextBlock Name="LoadedFileText" Text="(none)" />
        </StackPanel>
        <TextBlock Name="SaveInfoText" TextWrapping="Wrap" />
    </StackPanel>
</Window>
